  <meta property="og:image" content="https://ericanordlof.github.io/offroadbumpis/Bumperball%20p%C3%A5%20fotbollsplan%20i%20Veber%C3%B6d.png">
  <meta property="og:url" content="https://ericanordlof.github.io/offroadbumpis/skolaktivitet/skane">
  <meta property="og:type" content="website">
  <meta name="theme-color" content="#14361b" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Baloo+2:wght@600;700;800&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <style>
    :root{
      --bg:#f5fff1;
      --bg-2:#ecffe4;
      --card:#ffffff;
      --text:#16311d;
      --muted:#4d6454;
      --line:rgba(18, 64, 29, 0.10);
      --green:#74d64c;
      --green-dark:#2f7f25;
      --green-soft:#dff8d1;
      --yellow:#ffd84d;
      --orange:#ff9c3a;
      --dark:#102217;
      --dark-2:#14361b;
      --shadow:0 18px 55px rgba(14, 53, 22, 0.10);
      --shadow-soft:0 10px 28px rgba(14, 53, 22, 0.08);
      --radius:24px;
      --max:1180px;
      --safe-top:env(safe-area-inset-top, 0px);
      --safe-right:env(safe-area-inset-right, 0px);
      --safe-bottom:env(safe-area-inset-bottom, 0px);
      --safe-left:env(safe-area-inset-left, 0px);
    }

    *{box-sizing:border-box}

    html{
      scroll-behavior:smooth;
      -webkit-text-size-adjust:100%;
    }

    body{
      margin:0;
      min-width:320px;
      font-family:"Inter",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, #fdffe7 0, transparent 22%),
        radial-gradient(circle at top right, #e9ffd8 0, transparent 24%),
        linear-gradient(180deg, var(--bg) 0%, #effbea 100%);
      overflow-x:hidden;
      text-rendering:optimizeLegibility;
    }

    body.menu-open{
      overflow:hidden;
    }

    a{color:inherit;text-decoration:none}
    img{max-width:100%;display:block}

    a, button, summary, [role="button"]{
      -webkit-tap-highlight-color:transparent;
    }

    button{
      font:inherit;
    }

    .container{
      width:min(var(--max), calc(100% - 32px));
      margin:0 auto;
    }

    .topbar{
      position:sticky;
      top:0;
      z-index:60;
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      background:rgba(245,255,241,0.84);
      border-bottom:1px solid var(--line);
      padding-top:var(--safe-top);
    }

    .nav{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:16px;
      min-height:74px;
      padding:12px 0;
    }

    .brand{
      min-width:0;
      display:flex;
      align-items:center;
      gap:12px;
      font-weight:800;
      letter-spacing:-0.02em;
      flex:1 1 auto;
    }

    .brand span{
      display:block;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      font-size:16px;
    }

    .brand-logo{
      width:42px;
      height:42px;
      min-width:42px;
      object-fit:contain;
      border-radius:12px;
      box-shadow:var(--shadow-soft);
    }

    .nav-links{
      display:flex;
      align-items:center;
      gap:20px;
      color:#35523c;
      font-size:15px;
      font-weight:700;
      flex-wrap:wrap;
    }

    .nav-links a{
      white-space:nowrap;
    }

    .nav-cta{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:48px;
      padding:12px 18px;
      border-radius:999px;
      background:var(--dark);
      color:#fff;
      font-weight:800;
      box-shadow:var(--shadow-soft);
      text-align:center;
      line-height:1.2;
      flex-shrink:0;
    }

    .menu-toggle{
      display:none;
      align-items:center;
      justify-content:center;
      width:46px;
      height:46px;
      border:none;
      border-radius:14px;
      background:#fff;
      border:1px solid var(--line);
      box-shadow:var(--shadow-soft);
      color:var(--dark);
      cursor:pointer;
      flex-shrink:0;
    }

    .menu-toggle svg{
      width:22px;
      height:22px;
      display:block;
    }

    .mobile-menu{
      display:none;
      position:fixed;
      inset:0;
      z-index:80;
      background:rgba(16, 34, 23, 0.36);
      backdrop-filter:blur(8px);
      -webkit-backdrop-filter:blur(8px);
      padding:
        calc(14px + var(--safe-top))
        calc(14px + var(--safe-right))
        calc(14px + var(--safe-bottom))
        calc(14px + var(--safe-left));
      opacity:0;
      pointer-events:none;
      transition:opacity .22s ease;
    }

    .mobile-menu.is-open{
      opacity:1;
      pointer-events:auto;
    }

    .mobile-menu-panel{
      width:min(100%, 420px);
      margin-left:auto;
      background:linear-gradient(180deg, #ffffff 0%, #f6fff2 100%);
      border:1px solid rgba(18,64,29,0.10);
      border-radius:28px;
      box-shadow:0 28px 70px rgba(8, 34, 16, 0.22);
      padding:16px;
      transform:translateY(10px);
      transition:transform .22s ease;
      max-height:100%;
      overflow:auto;
    }

    .mobile-menu.is-open .mobile-menu-panel{
      transform:translateY(0);
    }

    .mobile-menu-top{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom:14px;
    }

    .mobile-menu-title{
      font-weight:900;
      font-size:15px;
      color:#23402b;
    }

    .mobile-close{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      width:42px;
      height:42px;
      border:none;
      border-radius:12px;
      background:#fff;
      border:1px solid var(--line);
      cursor:pointer;
      color:#16311d;
    }

    .mobile-close svg{
      width:20px;
      height:20px;
      display:block;
    }

    .mobile-menu-links{
      display:grid;
      gap:10px;
      margin-top:8px;
    }

    .mobile-menu-link{
      display:flex;
      align-items:center;
      justify-content:space-between;
      min-height:52px;
      padding:14px 16px;
      border-radius:18px;
      background:#fff;
      border:1px solid var(--line);
      box-shadow:0 8px 22px rgba(0,0,0,0.04);
      font-weight:800;
      color:#23402b;
      line-height:1.3;
    }

    .mobile-menu-link span:last-child{
      color:#7a9a81;
      font-weight:900;
    }

    .mobile-menu-cta{
      margin-top:14px;
      width:100%;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:54px;
      padding:14px 18px;
      border-radius:999px;
      background:var(--dark);
      color:#fff;
      font-weight:900;
      box-shadow:var(--shadow-soft);
      text-align:center;
    }

    .hero{
      padding:46px 0 24px;
    }

    .hero-grid{
      display:grid;
      grid-template-columns:1.02fr 0.98fr;
      gap:28px;
      align-items:center;
    }

    .eyebrow{
      display:inline-flex;
      align-items:center;
      gap:8px;
      max-width:100%;
      padding:8px 12px;
      background:#fff;
      border:1px solid var(--line);
      border-radius:999px;
      font-size:13px;
      font-weight:800;
      color:#42634a;
      box-shadow:0 10px 24px rgba(0,0,0,0.04);
      line-height:1.35;
      flex-wrap:wrap;
    }

    h1, h2, h3, h4{
      font-family:"Baloo 2", sans-serif;
      letter-spacing:-0.03em;
      margin:0;
      color:#14361b;
      word-break:break-word;
      overflow-wrap:anywhere;
    }

    .hero h1{
      margin:14px 0 14px;
      font-size:clamp(2.35rem, 8vw, 5.6rem);
      line-height:0.95;
      max-width:12ch;
    }

    .hero p{
      margin:0;
      font-size:18px;
      line-height:1.72;
      color:#3f5c46;
      max-width:680px;
    }

    .hero-trust{
      margin-top:14px;
      color:#36553d;
      font-size:15px;
      line-height:1.7;
      font-weight:600;
    }

    .hero-points{
      display:grid;
      gap:10px;
      margin:22px 0 0;
      padding:0;
      list-style:none;
      color:#2c4632;
      font-weight:600;
    }

    .hero-points li{
      display:flex;
      gap:10px;
      align-items:flex-start;
    }

    .check{
      flex:0 0 auto;
      width:24px;
      height:24px;
      border-radius:50%;
      display:grid;
      place-items:center;
      background:var(--green-dark);
      color:#fff;
      font-size:13px;
      font-weight:800;
      margin-top:1px;
      line-height:1;
    }

    .hero-actions{
      display:flex;
      gap:14px;
      flex-wrap:wrap;
      margin-top:26px;
    }

    .btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      gap:10px;
      min-height:52px;
      padding:14px 20px;
      border-radius:999px;
      font-weight:800;
      transition:.2s ease;
      border:none;
      cursor:pointer;
      font:inherit;
      text-align:center;
      line-height:1.25;
      white-space:normal;
    }

    .btn:hover{transform:translateY(-1px)}
    .btn:active{transform:translateY(0)}

    .btn-primary{
      background:var(--dark);
      color:#fff;
      box-shadow:var(--shadow-soft);
    }

    .btn-secondary{
      background:#fff;
      color:var(--text);
      border:1px solid var(--line);
    }

    .hero-card{
      background:linear-gradient(180deg, #1b4724 0%, #14361b 100%);
      color:#fff;
      border-radius:30px;
      padding:18px;
      box-shadow:0 28px 80px rgba(8, 34, 16, 0.18);
      overflow:hidden;
      position:relative;
      isolation:isolate;
    }

    .hero-card::after{
      content:"";
      position:absolute;
      right:-90px;
      bottom:-90px;
      width:240px;
      height:240px;
      border-radius:50%;
      background:radial-gradient(circle, rgba(255,255,255,0.16), transparent 70%);
      pointer-events:none;
      z-index:-1;
    }

    .mockup-header{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      margin-bottom:14px;
      color:#d7ead8;
      font-size:14px;
      font-weight:700;
      line-height:1.45;
    }

    .dots{
      display:flex;
      gap:6px;
      flex-shrink:0;
    }

    .dots span{
      width:9px;
      height:9px;
      border-radius:50%;
      background:#6aa85b;
    }

    .mockup-image{
      border-radius:24px;
      overflow:hidden;
      margin-bottom:14px;
      aspect-ratio:4/5;
      background:#1f3826;
    }

    .mockup-image img{
      width:100%;
      height:100%;
      object-fit:cover;
    }

    .mockup-panel{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:10px;
    }

    .mini-card{
      background:rgba(255,255,255,0.09);
      border:1px solid rgba(255,255,255,0.08);
      border-radius:18px;
      padding:12px;
      min-height:88px;
    }

    .mini-card strong{
      display:block;
      font-size:13px;
      line-height:1.45;
      color:#f2faf2;
    }

    .section{
      padding:42px 0;
      scroll-margin-top:96px;
    }

    .section-title{
      display:flex;
      justify-content:space-between;
      align-items:end;
      gap:18px;
      margin-bottom:20px;
    }

    .section-title h2{
      font-size:clamp(2rem, 4vw, 3.4rem);
      line-height:0.98;
    }

    .section-title p{
      margin:0;
      max-width:620px;
      line-height:1.7;
      color:var(--muted);
    }

    .grid-2{
      display:grid;
      grid-template-columns:repeat(2,1fr);
      gap:18px;
    }

    .card{
      background:rgba(255,255,255,0.92);
      border:1px solid var(--line);
      border-radius:var(--radius);
      padding:22px;
      box-shadow:var(--shadow);
      min-width:0;
    }

    .card h3{
      font-size:28px;
      margin-bottom:10px;
      line-height:1.02;
    }

    .card p{
      margin:0;
      color:var(--muted);
      line-height:1.7;
    }

    .price-grid{
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:18px;
      align-items:stretch;
    }

    .price-card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:28px;
      padding:24px;
      box-shadow:var(--shadow);
      position:relative;
      overflow:hidden;
      min-width:0;
    }

    .price-card.featured{
      background:linear-gradient(180deg, #14371b 0%, #102817 100%);
      color:#fff;
      transform:translateY(-8px);
    }

    .tag{
      display:inline-block;
      font-size:12px;
      font-weight:800;
      letter-spacing:.04em;
      text-transform:uppercase;
      padding:8px 10px;
      border-radius:999px;
      background:rgba(18,49,29,0.08);
      line-height:1.2;
    }

    .featured .tag{
      background:rgba(255,255,255,0.12);
      color:#e9ffe8;
    }

    .price-card h3{
      margin:16px 0 8px;
      font-size:30px;
      line-height:1;
      color:inherit;
    }

    .price{
      font-size:48px;
      font-weight:900;
      letter-spacing:-0.06em;
      line-height:1;
      margin:0 0 10px;
      font-family:"Baloo 2", sans-serif;
    }

    .price-note{
      margin-bottom:16px;
      color:#627066;
      font-weight:600;
      line-height:1.6;
    }

    .featured .price-note{
      color:#d7e8d7;
    }

    .feature-list{
      list-style:none;
      padding:0;
      margin:0;
      display:grid;
      gap:10px;
    }

    .feature-list li{
      display:flex;
      gap:10px;
      color:#425646;
      line-height:1.6;
      align-items:flex-start;
    }

    .featured .feature-list li{
      color:#eef6ee;
    }

    .pill-row{
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .pill{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:42px;
      padding:10px 14px;
      border-radius:999px;
      background:#fff;
      border:1px solid var(--line);
      font-weight:700;
      color:#35523d;
      box-shadow:0 8px 22px rgba(0,0,0,0.04);
      text-align:center;
      line-height:1.3;
    }

    .zone-grid,
    .city-grid,
    .games{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:16px;
    }

    .zone-card,
    .city-card,
    .game-card{
      background:#fff;
      border:1px solid var(--line);
      border-radius:24px;
      padding:20px;
      box-shadow:var(--shadow);
      min-width:0;
    }

    .city-card{
      display:block;
      transition:.2s ease;
      min-height:178px;
    }

    .city-card:hover{
      transform:translateY(-2px);
      box-shadow:0 16px 34px rgba(0,0,0,0.08);
    }

    .zone-card strong,
    .city-card strong{
      display:block;
      font-size:24px;
      font-family:"Baloo 2", sans-serif;
      margin-bottom:6px;
      line-height:1;
      color:#14361b;
    }

    .zone-card .zone-price{
      font-weight:900;
      font-size:22px;
      color:#1d4e26;
      margin-bottom:8px;
      line-height:1.15;
    }

    .zone-card p,
    .city-card span,
    .game-card p{
      margin:0;
      color:var(--muted);
      line-height:1.65;
      font-size:14px;
    }

    .showcase{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:18px;
      align-items:stretch;
    }

    .showcase .card{
      padding:0;
      overflow:hidden;
    }

    .showcase-content{
      padding:26px;
    }

    .showcase img{
      width:100%;
      aspect-ratio:16/10;
      object-fit:cover;
    }

    .steps{
      display:grid;
      gap:12px;
      margin-top:18px;
    }

    .step{
      display:grid;
      grid-template-columns:46px 1fr;
      gap:14px;
      align-items:start;
    }

    .step-number{
      width:46px;
      height:46px;
      border-radius:16px;
      display:grid;
      place-items:center;
      background:linear-gradient(135deg, var(--green), var(--yellow));
      color:#14311b;
      font-weight:900;
      font-size:20px;
      font-family:"Baloo 2", sans-serif;
      line-height:1;
      flex-shrink:0;
    }

    .step h4{
      margin:0 0 6px;
      font-size:21px;
      line-height:1;
      color:#14361b;
    }

    .step p{
      margin:0;
      color:var(--muted);
      line-height:1.7;
    }

    .game-card h3{
      font-size:24px;
      margin-bottom:8px;
      line-height:1;
      color:#14361b;
    }

    .game-tags{
      display:flex;
      flex-wrap:wrap;
      gap:8px;
      margin-top:14px;
    }

    .game-tags span{
      padding:8px 10px;
      border-radius:999px;
      background:var(--green-soft);
      color:#24542f;
      font-size:13px;
      font-weight:800;
      line-height:1.2;
    }

    .faq{
      display:grid;
      gap:12px;
    }

    details{
      background:#fff;
      border:1px solid var(--line);
      border-radius:20px;
      padding:16px 18px;
      box-shadow:0 8px 22px rgba(0,0,0,0.04);
    }

    summary{
      cursor:pointer;
      font-weight:800;
      list-style:none;
      line-height:1.45;
      padding-right:22px;
      position:relative;
    }

    summary::-webkit-details-marker{
      display:none;
    }

    summary::after{
      content:"+";
      position:absolute;
      right:0;
      top:0;
      font-size:20px;
      line-height:1;
      color:#2f7f25;
      font-weight:900;
    }

    details[open] summary::after{
      content:"–";
    }

    details p{
      margin:12px 0 0;
      color:var(--muted);
      line-height:1.75;
    }

    .trust-card{
      background:linear-gradient(135deg, #14361b 0%, #0d2113 100%);
      color:#fff;
      border-radius:30px;
      padding:28px;
      box-shadow:var(--shadow);
    }

    .trust-card h2{
      font-size:clamp(2rem, 4vw, 3rem);
      margin-bottom:12px;
      color:#fff;
      line-height:0.98;
    }

    .trust-card p{
      margin:0;
      color:#d7e8d8;
      line-height:1.8;
      max-width:860px;
    }

    .trust-actions{
      display:flex;
      gap:12px;
      flex-wrap:wrap;
      margin-top:20px;
    }

    .cta{
      background:linear-gradient(135deg, #14361b 0%, #0d2113 100%);
      color:#fff;
      border-radius:34px;
      padding:34px;
      box-shadow:var(--shadow);
      display:grid;
      grid-template-columns:1.1fr 0.9fr;
      gap:20px;
      align-items:start;
    }

    .cta-copy h2{
      font-size:clamp(2rem, 4vw, 3.2rem);
      margin-bottom:10px;
      color:#fff;
      line-height:0.98;
    }

    .cta-copy p{
      margin:0 0 18px;
      color:#d7e8d8;
      line-height:1.75;
      max-width:620px;
    }

    .cta-buttons{
      display:flex;
      flex-wrap:wrap;
      gap:12px;
      margin-top:20px;
    }

    .contact-box{
      background:rgba(255,255,255,0.08);
      border:1px solid rgba(255,255,255,0.10);
      border-radius:24px;
      padding:22px;
      display:grid;
      gap:12px;
      min-width:0;
    }

    .contact-box strong{
      display:block;
      margin-bottom:2px;
      font-size:20px;
      color:#fff;
      line-height:1.1;
    }

    .contact-box small{
      color:rgba(255,255,255,0.78);
      line-height:1.6;
    }

    .contact-links{
      display:grid;
