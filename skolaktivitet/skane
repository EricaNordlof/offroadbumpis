  <script>
    (function () {
      const body = document.body;
      const menu = document.getElementById("mobileMenu");
      const toggle = document.querySelector(".menu-toggle");
      const closeBtn = document.querySelector(".mobile-close");
      const menuLinks = menu ? menu.querySelectorAll("a") : [];

      if (menu && toggle && closeBtn) {
        function openMenu() {
          menu.classList.add("is-open");
          menu.setAttribute("aria-hidden", "false");
          toggle.setAttribute("aria-expanded", "true");
          body.classList.add("menu-open");
        }

        function closeMenu() {
          menu.classList.remove("is-open");
          menu.setAttribute("aria-hidden", "true");
          toggle.setAttribute("aria-expanded", "false");
          body.classList.remove("menu-open");
        }

        toggle.addEventListener("click", openMenu);
        closeBtn.addEventListener("click", closeMenu);

        menu.addEventListener("click", function (event) {
          if (event.target === menu) closeMenu();
        });

        menuLinks.forEach(function (link) {
          link.addEventListener("click", closeMenu);
        });

        document.addEventListener("keydown", function (event) {
          if (event.key === "Escape" && menu.classList.contains("is-open")) {
            closeMenu();
          }
        });
      }

      const stickyEyebrow = document.getElementById("mobileStickyEyebrow");
      const stickyTitle = document.getElementById("mobileStickyTitle");
      const stickyButton = document.getElementById("mobileStickyButton");

      if (!stickyEyebrow || !stickyTitle || !stickyButton) return;

      const sections = [
        {
          el: document.querySelector(".hero"),
          eyebrow: "Skolaktivitet Skåne",
          title: "Boka bumperball direkt online",
          button: "Boka nu"
        },
        {
          el: document.getElementById("paket"),
          eyebrow: "Pris & paket",
          title: "Se priset och boka rätt upplägg",
          button: "Se pris"
        },
        {
          el: document.getElementById("stad"),
          eyebrow: "Städer i Skåne",
          title: "Hitta rätt ort och boka",
          button: "Se städer"
        },
        {
          el: document.getElementById("spel"),
          eyebrow: "Spelidéer",
          title: "Redo att köra? Säkra datumet",
          button: "Säkra datum"
        },
        {
          el: document.getElementById("faq"),
          eyebrow: "Vanliga frågor",
          title: "Allt klart? Boka aktiviteten",
          button: "Boka aktivitet"
        },
        {
          el: document.getElementById("kontakt"),
          eyebrow: "Kontakt & bokning",
          title: "Boka direkt eller mejla",
          button: "Boka direkt"
        }
      ].filter(function (item) {
        return item.el;
      });

      function updateStickyContent() {
        if (window.innerWidth > 720 || sections.length === 0) return;

        const triggerY = window.innerHeight * 0.34;
        let active = sections[0];

        for (let i = 0; i < sections.length; i++) {
          const rect = sections[i].el.getBoundingClientRect();
          if (rect.top <= triggerY) {
            active = sections[i];
          }
        }

        stickyEyebrow.textContent = active.eyebrow;
        stickyTitle.textContent = active.title;
        stickyButton.textContent = active.button;
      }

      let ticking = false;

      function onScrollOrResize() {
        if (!ticking) {
          window.requestAnimationFrame(function () {
            updateStickyContent();
            ticking = false;
          });
          ticking = true;
        }
      }

      updateStickyContent();
      window.addEventListener("scroll", onScrollOrResize, { passive: true });
      window.addEventListener("resize", onScrollOrResize);
      window.addEventListener("orientationchange", onScrollOrResize);
    })();
  </script>
